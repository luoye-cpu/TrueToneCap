<Window x:Class="TrueToneCap.App.SelectionOverlay"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="SelectionOverlay"
    Closed="OnClosed">

    <Grid x:Name="RootGrid" IsTabStop="True">
        <!-- 桌面截图背景（拉伸填充，确保覆盖整个窗口） -->
        <Image x:Name="DesktopImage" Stretch="Fill" IsHitTestVisible="False"/>

        <!-- 半透明覆盖层：等待用户单击或框选 -->
        <Border x:Name="DimOverlay" Background="#66000000" IsHitTestVisible="False"/>

        <!-- 选区外遮罩 -->
        <Grid x:Name="MaskGrid" IsHitTestVisible="False">
            <Border x:Name="MaskTop" Background="#66000000" IsHitTestVisible="False" VerticalAlignment="Top"/>
            <Border x:Name="MaskBottom" Background="#66000000" IsHitTestVisible="False" VerticalAlignment="Bottom"/>
            <Border x:Name="MaskLeft" Background="#66000000" IsHitTestVisible="False" HorizontalAlignment="Left"/>
            <Border x:Name="MaskRight" Background="#66000000" IsHitTestVisible="False" HorizontalAlignment="Right"/>
        </Grid>

        <!-- 选区四边蓝色细线（取代边框） -->
        <Rectangle x:Name="SelLineTop"    Fill="#FF4488FF" Height="1.5" Visibility="Collapsed"
                   IsHitTestVisible="False" HorizontalAlignment="Left" VerticalAlignment="Top"/>
        <Rectangle x:Name="SelLineBottom" Fill="#FF4488FF" Height="1.5" Visibility="Collapsed"
                   IsHitTestVisible="False" HorizontalAlignment="Left" VerticalAlignment="Top"/>
        <Rectangle x:Name="SelLineLeft"   Fill="#FF4488FF" Width="1.5"  Visibility="Collapsed"
                   IsHitTestVisible="False" HorizontalAlignment="Left" VerticalAlignment="Top"/>
        <Rectangle x:Name="SelLineRight"  Fill="#FF4488FF" Width="1.5"  Visibility="Collapsed"
                   IsHitTestVisible="False" HorizontalAlignment="Left" VerticalAlignment="Top"/>

        <!-- 尺寸标签（选区上方居中） -->
        <Border x:Name="SizeLabelBorder" Background="#FF4488FF" CornerRadius="3"
                HorizontalAlignment="Left" VerticalAlignment="Top"
                Visibility="Collapsed" IsHitTestVisible="False"
                Padding="6,2">
            <TextBlock x:Name="SizeLabel" FontSize="11" Foreground="White" Text="0 x 0"/>
        </Border>

        <!-- 标注画布（进入标注模式后置于选区之上，实时显示标注） -->
        <Canvas x:Name="AnnotationCanvas" Background="Transparent"
                Visibility="Collapsed" HorizontalAlignment="Left" VerticalAlignment="Top"/>

        <TextBlock x:Name="HintText"
                   Text="单击 = 全屏  |  拖拽 = 框选  |  Esc = 取消"
                   FontSize="14" Foreground="#CCFFFFFF"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   IsHitTestVisible="False"/>

        <!-- ═══════ 主操作工具栏（选区完成后显示） ═══════ -->
        <Border x:Name="Toolbar" 
                Background="#F2FFFFFF" CornerRadius="8" 
                BorderBrush="#FF888888" BorderThickness="1"
                Padding="6,4" Visibility="Collapsed"
                HorizontalAlignment="Left" VerticalAlignment="Top">
            <StackPanel Orientation="Horizontal" Spacing="4">
                <Button x:Name="BtnConfirm" Width="70" Height="36"
                        Click="OnConfirm" ToolTipService.ToolTip="保存截图到文件并复制 (Enter)"
                        Background="#FF4488FF" Foreground="White">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <FontIcon Glyph="&#xE8FB;" FontSize="14"/>
                        <TextBlock Text="保存" FontSize="12" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button x:Name="BtnAnnotate" Width="70" Height="36"
                        Click="OnAnnotate" ToolTipService.ToolTip="标注选区（矩形/箭头/马赛克等）">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <FontIcon Glyph="&#xE70F;" FontSize="14"/>
                        <TextBlock Text="标注" FontSize="12" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button x:Name="BtnCopy" Width="70" Height="36"
                        Click="OnCopy" ToolTipService.ToolTip="复制图像到剪贴板">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <FontIcon Glyph="&#xE8C8;" FontSize="14"/>
                        <TextBlock Text="复制" FontSize="12" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button x:Name="BtnOcr" Width="70" Height="36"
                        Click="OnOcr" ToolTipService.ToolTip="识别图中文字 (OCR)">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <FontIcon Glyph="&#xE8A9;" FontSize="14"/>
                        <TextBlock Text="识字" FontSize="12" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button x:Name="BtnTranslate" Width="70" Height="36"
                        Click="OnTranslate" ToolTipService.ToolTip="翻译图中文字">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <FontIcon Glyph="&#xE909;" FontSize="14"/>
                        <TextBlock Text="翻译" FontSize="12" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button x:Name="BtnCancel" Width="58" Height="36"
                        Click="OnCancel" ToolTipService.ToolTip="取消选区 (Esc)">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <FontIcon Glyph="&#xE10A;" FontSize="14"/>
                        <TextBlock Text="取消" FontSize="12" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>

        <!-- ═══════ 标注工具栏（标注模式下显示） ═══════ -->
        <Border x:Name="AnnotationToolbar" 
                Background="#F2FFFFFF" CornerRadius="8" 
                BorderBrush="#FF888888" BorderThickness="1"
                Padding="6,4" Visibility="Collapsed"
                HorizontalAlignment="Left" VerticalAlignment="Top">
            <StackPanel Orientation="Horizontal" Spacing="3">
                <Button x:Name="AnnoRectBtn" Width="34" Height="34" Click="OnAnnoToolClick" Tag="Rect"
                        ToolTipService.ToolTip="矩形 (R)">
                    <FontIcon Glyph="&#xE7FB;" FontSize="16"/>
                </Button>
                <Button x:Name="AnnoEllipseBtn" Width="34" Height="34" Click="OnAnnoToolClick" Tag="Ellipse"
                        ToolTipService.ToolTip="椭圆 (E)">
                    <FontIcon Glyph="&#xE8D8;" FontSize="16"/>
                </Button>
                <Button x:Name="AnnoArrowBtn" Width="34" Height="34" Click="OnAnnoToolClick" Tag="Arrow"
                        ToolTipService.ToolTip="箭头 (A)">
                    <FontIcon Glyph="&#xE72A;" FontSize="16"/>
                </Button>
                <Button x:Name="AnnoPenBtn" Width="34" Height="34" Click="OnAnnoToolClick" Tag="Pen"
                        ToolTipService.ToolTip="画笔 (P)">
                    <FontIcon Glyph="&#xE84F;" FontSize="16"/>
                </Button>
                <Button x:Name="AnnoTextBtn" Width="34" Height="34" Click="OnAnnoToolClick" Tag="Text"
                        ToolTipService.ToolTip="文字 (T)">
                    <FontIcon Glyph="&#xE8D4;" FontSize="16"/>
                </Button>
                <Button x:Name="AnnoMosaicBtn" Width="34" Height="34" Click="OnAnnoToolClick" Tag="Mosaic"
                        ToolTipService.ToolTip="马赛克 (M)">
                    <FontIcon Glyph="&#xE7F1;" FontSize="16"/>
                </Button>
                <Rectangle Width="1" Fill="#FF888888" Margin="6,4"/>
                <Button x:Name="AnnoUndoBtn" Width="34" Height="34" Click="OnAnnoUndo"
                        ToolTipService.ToolTip="撤销 (Ctrl+Z)">
                    <FontIcon Glyph="&#xE7A7;" FontSize="16"/>
                </Button>
                <Button x:Name="AnnoRedoBtn" Width="34" Height="34" Click="OnAnnoRedo"
                        ToolTipService.ToolTip="重做 (Ctrl+Y)">
                    <FontIcon Glyph="&#xE7A6;" FontSize="16"/>
                </Button>
                <Rectangle Width="1" Fill="#FF888888" Margin="6,4"/>
                <Button x:Name="AnnoDoneBtn" Width="64" Height="34" Click="OnAnnoDone"
                        Background="#FF4488FF" Foreground="White"
                        ToolTipService.ToolTip="完成标注 (Esc)">
                    <StackPanel Orientation="Horizontal" Spacing="3">
                        <FontIcon Glyph="&#xE8FB;" FontSize="14"/>
                        <TextBlock Text="完成" FontSize="12" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</Window>
