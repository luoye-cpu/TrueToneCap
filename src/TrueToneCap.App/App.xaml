<!-- TrueToneCap.App/App.xaml -->
<Application
    x:Class="TrueToneCap.App.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <ResourceDictionary>
            <!-- ═══ 覆盖 WinUI 主题字体 ═══ -->
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Default">
                    <FontFamily x:Key="ContentControlThemeFontFamily">Microsoft YaHei, HarmonyOS Sans SC, Segoe UI, sans-serif</FontFamily>
                    <FontFamily x:Key="TextControlThemeFontFamily">Microsoft YaHei, HarmonyOS Sans SC, Segoe UI, sans-serif</FontFamily>
                </ResourceDictionary>
                <ResourceDictionary x:Key="Light">
                    <FontFamily x:Key="ContentControlThemeFontFamily">Microsoft YaHei, HarmonyOS Sans SC, Segoe UI, sans-serif</FontFamily>
                    <FontFamily x:Key="TextControlThemeFontFamily">Microsoft YaHei, HarmonyOS Sans SC, Segoe UI, sans-serif</FontFamily>
                </ResourceDictionary>
                <ResourceDictionary x:Key="Dark">
                    <FontFamily x:Key="ContentControlThemeFontFamily">Microsoft YaHei, HarmonyOS Sans SC, Segoe UI, sans-serif</FontFamily>
                    <FontFamily x:Key="TextControlThemeFontFamily">Microsoft YaHei, HarmonyOS Sans SC, Segoe UI, sans-serif</FontFamily>
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>

            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>

            <!-- 全局默认字体隐式回退 -->
            <Style TargetType="TextBlock">
                <Setter Property="FontFamily" Value="Microsoft YaHei, HarmonyOS Sans SC, Segoe UI, sans-serif" />
            </Style>
            <Style TargetType="Control">
                <Setter Property="FontFamily" Value="Microsoft YaHei, HarmonyOS Sans SC, Segoe UI, sans-serif" />
            </Style>

            <!-- 应用级主题色 -->
            <SolidColorBrush x:Key="AccentBrush" Color="#FF0078D4"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
